{
  "name": "personal-os",
  "version": "0.1.0",
  "description": "A life/work/learning management system built entirely on Markdown for Obsidian.",
  "main": "main.js",
  "type": "module",
  "workspaces": [
    "webapp"
  ],
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && npm run webapp:build && node esbuild.config.mjs production",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json --config ./svelte.config.js",
    "webapp:dev": "npm run dev --workspace webapp",
    "webapp:build": "npm run build --workspace webapp"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.2",
    "esbuild-svelte": "^0.9.5",
    "obsidian": "^1.13.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
